<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Container do Player -->
    <FrameLayout
        android:id="@+id/player_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay de Informação do Canal -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="32dp"
        android:orientation="vertical"
        android:background="@drawable/channel_info_background"
        android:padding="16dp">

        <TextView
            android:id="@+id/channel_number_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/channel_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="@android:color/white"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Lista de Canais (aparece ao apertar OK) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/channel_list_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:visibility="gone" />

</FrameLayout>