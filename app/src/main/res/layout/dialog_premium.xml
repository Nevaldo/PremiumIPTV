<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="@drawable/bg_dialog_premium">

    <!-- ICONE -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_dialog_icon"
        android:gravity="center">

        <ImageView
            android:id="@+id/dialogIcon"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_margin="10dp"
            android:src="@drawable/ic_exit_player"
            app:tint="#8A2EFF" />

    </LinearLayout>

    <!-- TITULO -->
    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="15dp"
        android:text="Sair do Player"
        android:textColor="#FFFFFF"
        android:textSize="19sp"
        android:textStyle="bold" />

    <!-- MENSAGEM -->
    <TextView
        android:id="@+id/dialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Tem certeza que deseja sair do player?"
        android:textColor="#BDBDBD"
        android:textSize="14sp" />

    <!-- BOTOES -->
    <LinearLayout
        android:layout_width="430dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_button_secondary"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="#D5D5D5"
            android:textSize="16sp"/>

        <Space
            android:layout_width="18dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_button_primary"
            android:text="Sair"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

    </LinearLayout>

</LinearLayout>