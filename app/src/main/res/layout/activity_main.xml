<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_main"
    android:animateLayoutChanges="true"
    tools:context=".MainActivity">

    <!-- Sidebar esquerda expandida (idêntica à imagem) -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:orientation="vertical"
        android:background="@color/bg_sidebar">

        <!-- Logo + App Title -->
        <LinearLayout
            android:id="@+id/leftGroup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/star_on"
                app:tint="@color/colorAccent" />

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Início"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="10dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Menu Items -->
        <LinearLayout
            android:id="@+id/menuContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp">

            <!-- Inicio (ATIVO) -->
            <LinearLayout
                android:id="@+id/menuInicio"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item_active"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_inicio"
                    app:tint="@color/text_primary" />
                <TextView
                    android:id="@+id/tvMenuInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Início"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Ao Vivo -->
            <LinearLayout
                android:id="@+id/menuAoVivo"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_ao_vivo"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuAoVivo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ao Vivo"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Filmes -->
            <LinearLayout
                android:id="@+id/menuFilmes"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_filmes"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuFilmes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filmes"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Séries -->
            <LinearLayout
                android:id="@+id/menuSeries"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_series"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuSeries"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Séries"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Favoritos -->
            <LinearLayout
                android:id="@+id/menuFavoritos"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_favoritos"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuFavoritos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Favoritos"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Listas -->
            <LinearLayout
                android:id="@+id/menuListas"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_listas"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuListas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Listas"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Histórico -->
            <LinearLayout
                android:id="@+id/menuHistorico"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_historico"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuHistorico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Histórico"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Categorias -->
            <LinearLayout
                android:id="@+id/menuCategorias"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_menu_categorias"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuCategorias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categorias"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Configurações -->
            <LinearLayout
                android:id="@+id/menuConfiguracoes"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_item"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvMenuConfiguracoes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configurações"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="14dp"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>

        <!-- Premium Banner (parte inferior da sidebar) -->
        <LinearLayout
            android:id="@+id/premiumCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_premium_card"
            android:padding="14dp"
            android:layout_margin="10dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💎"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tvPremiumTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PREMIUM"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvPremiumDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Muito mais conteúdo.\nSem anúncios.\nExperiência máxima."
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnPremiumTop"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="10dp"
                android:text="SEJA PREMIUM"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_menu_item_active"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Main Content Area (Fragment Container) -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/sidebar" />

    <!-- Hidden: Search menu (não usado mas mantido para compatibilidade) -->
    <LinearLayout
        android:id="@+id/menuSearch"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Top Bar oculto (mantido para compatibilidade com código Java) -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">
        <LinearLayout
            android:id="@+id/rightGroup"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </RelativeLayout>

</RelativeLayout>
