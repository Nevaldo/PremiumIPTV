<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_main">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Background Image Simulation -->
        <View
            android:id="@+id/bgImage"
            android:layout_width="match_parent"
            android:layout_height="500dp"
            android:background="#222222" 
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="500dp"
            android:background="@drawable/bg_fade_bottom"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Top Left "Voltar" -->
        <LinearLayout
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_margin="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="&lt; " android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VOLTAR" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Series Info Container -->
        <LinearLayout
            android:id="@+id/seriesInfoContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnVoltar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRAMA • AVENTURA • FANTASIA"
                android:textColor="@color/colorAccent"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Game of Thrones"
                android:textColor="@color/text_primary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <!-- Tags -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">
                
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2011 - 2019" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 18 " android:textColor="@color/text_primary" android:background="#333333" android:textSize="10sp" android:layout_marginStart="8dp" android:paddingHorizontal="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 8 Temporadas " android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 73 Episódios " android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 4K " android:textColor="#FFB74D" android:background="#332A1C" android:textSize="10sp" android:layout_marginStart="8dp" android:paddingHorizontal="4dp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Synopsis -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Em uma terra onde o verão pode durar décadas e o inverno uma vida inteira, conflitos entre nobres famílias disputam o controle dos Sete Reinos de Westeros."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="16dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:id="@+id/btnAssistir"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_btn_primary"
                    android:paddingHorizontal="24dp">
                    
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▶ " android:textColor="@color/text_primary" android:textSize="16sp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ASSISTIR" android:textColor="@color/text_primary" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T1 • E1" android:textColor="@color/text_primary" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnMinhaLista"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:text="+ MINHA LISTA"
                    android:backgroundTint="#00000000"
                    android:background="@drawable/bg_btn_outline"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="16dp"
                    android:paddingHorizontal="24dp"/>
            </LinearLayout>
            
            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:paddingBottom="8dp">
                
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EPISÓDIOS" android:textColor="@color/colorAccent" android:textStyle="bold" android:layout_marginEnd="24dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TEMPORADAS" android:textColor="@color/text_secondary" android:layout_marginEnd="24dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DETALHES" android:textColor="@color/text_secondary" android:layout_marginEnd="24dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ELENCO" android:textColor="@color/text_secondary" android:layout_marginEnd="24dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RECOMENDAÇÕES" android:textColor="@color/text_secondary"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#222233"/>
            <View android:layout_width="80dp" android:layout_height="2dp" android:background="@color/colorAccent" android:layout_marginTop="-2dp"/>

        </LinearLayout>

        <!-- Right Side Recommendation List -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#00000000"
            app:layout_constraintTop_toBottomOf="@id/btnVoltar"
            app:layout_constraintBottom_toTopOf="@id/bottomInfoRow"
            app:layout_constraintStart_toEndOf="@id/seriesInfoContainer"
            app:layout_constraintEnd_toEndOf="parent">
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="bottom">
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="MAIS COMO ESTA" android:textColor="@color/colorAccent" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ver mais →" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Recommendation Items Mock -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="60dp" android:background="@color/bg_surface" android:gravity="center_vertical" android:padding="8dp" android:layout_marginBottom="8dp">
                    <View android:layout_width="80dp" android:layout_height="match_parent" android:background="#333333" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="The Witcher" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2019 - 2023 | 3 Temporadas" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 8.1" android:textColor="@color/colorAccent" android:textSize="12sp"/>
                </LinearLayout>
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="60dp" android:background="@color/bg_surface" android:gravity="center_vertical" android:padding="8dp" android:layout_marginBottom="8dp">
                    <View android:layout_width="80dp" android:layout_height="match_parent" android:background="#333333" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vikings" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2013 - 2020 | 6 Temporadas" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 8.5" android:textColor="@color/colorAccent" android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Episodes Selector & Horizontal List -->
        <LinearLayout
            android:id="@+id/episodesRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/seriesInfoContainer"
            app:layout_constraintStart_toStartOf="@id/seriesInfoContainer"
            app:layout_constraintEnd_toEndOf="@id/seriesInfoContainer">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_btn_outline"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Temporada 1" android:textColor="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" ⌄" android:textColor="@color/text_secondary" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none"
                android:clipToPadding="false">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <!-- Episode 1 (Active) -->
                    <LinearLayout android:layout_width="160dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp" android:background="@drawable/bg_menu_item_active" android:padding="4dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="90dp" android:background="#333333">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_media_play" app:tint="@color/text_primary" android:layout_gravity="center" android:background="#88000000" android:padding="8dp"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Winter Is Coming" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="8dp" android:paddingHorizontal="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1h 02min" android:textColor="@color/text_secondary" android:textSize="10sp" android:paddingHorizontal="4dp" android:layout_marginBottom="4dp"/>
                    </LinearLayout>

                    <!-- Episode 2 -->
                    <LinearLayout android:layout_width="160dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp" android:background="@drawable/bg_btn_outline" android:padding="4dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="90dp" android:background="#333333"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2. The Kingsroad" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="bold" android:layout_marginTop="8dp" android:paddingHorizontal="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="56min" android:textColor="@color/text_secondary" android:textSize="10sp" android:paddingHorizontal="4dp" android:layout_marginBottom="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Bottom Info Row -->
        <HorizontalScrollView
            android:id="@+id/bottomInfoRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/episodesRow"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                
                <LinearLayout android:layout_width="140dp" android:layout_height="60dp" android:background="@drawable/bg_btn_outline" android:gravity="center_vertical" android:padding="12dp" android:layout_marginEnd="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" app:tint="@color/text_secondary" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ESTREIA" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="17 de abril de 2011" android:textColor="@color/text_primary" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="140dp" android:layout_height="60dp" android:background="@drawable/bg_btn_outline" android:gravity="center_vertical" android:padding="12dp" android:layout_marginEnd="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/star_off" app:tint="@color/text_secondary" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CRIAÇÃO" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="David Benioff" android:textColor="@color/text_primary" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
