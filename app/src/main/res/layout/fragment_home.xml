<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10">

        <!-- =====================================================
             PARTE 1: Conteúdo principal (~73%)
             ===================================================== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="7.3"
            android:orientation="vertical"
            android:padding="14dp"
            android:paddingEnd="10dp">

            <!-- ======= BANNER HERO DESTAQUE ======= -->
            <androidx.cardview.widget.CardView
                android:id="@+id/bannerCard"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="5dp"
                android:focusable="true"
                android:clickable="true"
                android:foreground="@drawable/bg_card_border">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Imagem de fundo do banner -->
                    <ImageView
                        android:id="@+id/bannerImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <!-- Gradiente sobre a imagem -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_fade_bottom" />

                    <!-- Badge "EM ALTA" -->
                    <TextView
                        android:id="@+id/bannerBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentStart="true"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="14dp"
                        android:text="EM ALTA"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_badge_em_alta"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />

                    <!-- Seta Esquerda -->
                    <ImageView
                        android:id="@+id/bannerPrev"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_media_previous"
                        android:background="#55000000"
                        android:padding="6dp"
                        android:focusable="true"
                        android:clickable="true" />

                    <!-- Seta Direita -->
                    <ImageView
                        android:id="@+id/bannerNext"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="8dp"
                        android:src="@android:drawable/ic_media_next"
                        android:background="#55000000"
                        android:padding="6dp"
                        android:focusable="true"
                        android:clickable="true" />

                    <!-- Info do banner (título, subtítulo, botões) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:background="#BB000000"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Título -->
                        <TextView
                            android:id="@+id/bannerTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <!-- Metadados: ano • duração • classificação -->
                        <TextView
                            android:id="@+id/bannerSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="3dp" />

                        <!-- Sinopse -->
                        <TextView
                            android:id="@+id/bannerDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#BBBBBB"
                            android:textSize="11sp"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:layout_marginTop="6dp" />

                        <!-- Botões de ação -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <!-- Assistir agora -->
                            <Button
                                android:id="@+id/btnBannerPlay"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="▶  Assistir agora"
                                android:textColor="@color/text_primary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_menu_item_active"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingHorizontal="14dp"
                                android:focusable="true"
                                android:clickable="true" />

                            <!-- Mais informações -->
                            <Button
                                android:id="@+id/btnBannerInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginStart="10dp"
                                android:text="ℹ  Mais informações"
                                android:textColor="@color/text_primary"
                                android:textSize="11sp"
                                android:background="@drawable/bg_btn_outline"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingHorizontal="14dp"
                                android:focusable="true"
                                android:clickable="true" />

                        </LinearLayout>

                    </LinearLayout>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <!-- ======= FILMES EM DESTAQUE ======= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Filmes em Destaque"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnVerTodosFilmes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todos ›"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:focusable="true"
                    android:clickable="true" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeaturedMovies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingEnd="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- ======= SÉRIES POPULARES ======= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Séries Populares"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnVerTodosSeries"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todas ›"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:focusable="true"
                    android:clickable="true" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeaturedSeries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingEnd="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

        <!-- =====================================================
             PARTE 2: Sidebar direita (~27%)
             ===================================================== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.7"
            android:orientation="vertical"
            android:padding="14dp"
            android:paddingStart="10dp">

            <!-- ======= CONTINUAR ASSISTINDO ======= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Continue Assistindo"
                android:textColor="@color/text_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContinueWatching"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:nestedScrollingEnabled="false" />

            <!-- Ver tudo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnHistorico"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:focusable="true"
                android:clickable="true"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="4dp"
                android:foreground="@drawable/bg_card_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver tudo"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ›"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ======= CATEGORIAS EM ALTA ======= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categorias em alta"
                android:textColor="@color/text_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp" />

            <!-- Grade de categorias 3x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Linha 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/catAcao"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:focusable="true"
                        android:clickable="true"
                        app:cardBackgroundColor="@color/bg_surface"
                        app:cardCornerRadius="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎬"
                                android:textSize="12sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ação"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/catDrama"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:focusable="true"
                        android:clickable="true"
                        app:cardBackgroundColor="@color/bg_surface"
                        app:cardCornerRadius="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎭"
                                android:textSize="12sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Drama"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/catComedia"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:focusable="true"
                        android:clickable="true"
                        app:cardBackgroundColor="@color/bg_surface"
                        app:cardCornerRadius="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="😄"
                                android:textSize="12sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Comédia"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Linha 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/catTerror"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:focusable="true"
                        android:clickable="true"
                        app:cardBackgroundColor="@color/bg_surface"
                        app:cardCornerRadius="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👻"
                                android:textSize="12sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Terror"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/catAnimacao"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:focusable="true"
                        android:clickable="true"
                        app:cardBackgroundColor="@color/bg_surface"
                        app:cardCornerRadius="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎨"
                                android:textSize="12sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Animação"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/catDocumentario"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:focusable="true"
                        android:clickable="true"
                        app:cardBackgroundColor="@color/bg_surface"
                        app:cardCornerRadius="6dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎞"
                                android:textSize="12sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Documentário"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <!-- ======= LANÇAMENTOS ======= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lançamentos"
                android:textColor="@color/text_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDestaque"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:focusable="true"
                android:clickable="true"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="10dp"
                android:foreground="@drawable/bg_card_border">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/destaqueImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_fade_bottom" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:background="#99000000"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/destaqueTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/destaqueSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />

                        <!-- Botão Assistir mini -->
                        <LinearLayout
                            android:id="@+id/btnDestaquePlay"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_menu_item_active"
                            android:paddingHorizontal="10dp"
                            android:focusable="true"
                            android:clickable="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="▶  Assistir agora"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
